#!/bin/bash
set -euo pipefail
echo ">>> [02] Installing AI coding tools..."

# Node.js (provides npm) from the NodeSource repo added in hook 01
apt-get install -y nodejs

# Claude Code CLI (via npm)
npm install -g @anthropic-ai/claude-code

# OpenAI Codex CLI (via npm)
npm install -g @openai/codex

# Aider (via pip)
pip3 install --break-system-packages aider-chat

echo ">>> [02] AI tools installed."
