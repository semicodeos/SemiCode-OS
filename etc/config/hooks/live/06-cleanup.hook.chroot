#!/bin/bash
set -euo pipefail
echo ">>> [06] Cleaning up to reduce ISO size..."

apt-get autoremove -y
apt-get clean
rm -rf /var/lib/apt/lists/*
rm -rf /tmp/*
rm -rf /var/tmp/*
rm -f /var/cache/apt/archives/*.deb
rm -f /var/cache/apt/archives/partial/*.deb
rm -f /var/cache/apt/*.bin

# Remove docs to save space (keep copyright files)
rm -rf /usr/share/doc/*.gz
rm -rf /usr/share/man/??
rm -rf /usr/share/man/??_*

echo ">>> [06] Cleanup complete."
